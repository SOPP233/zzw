#!/bin/sh
set -e

BASEDIR="$(cd "$(dirname "$0")" && pwd)"
WRAPPER_DIR="$BASEDIR/.mvn/wrapper"
MAVEN_VERSION="3.9.11"
MAVEN_DIST="apache-maven-${MAVEN_VERSION}-bin.tar.gz"
MAVEN_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/${MAVEN_VERSION}/${MAVEN_DIST}"
MAVEN_HOME="$WRAPPER_DIR/apache-maven-${MAVEN_VERSION}"
MAVEN_BIN="$MAVEN_HOME/bin/mvn"
JDK_VERSION="17"
JDK_DIST="temurin-${JDK_VERSION}-jdk.tar.gz"
JDK_URL="https://api.adoptium.net/v3/binary/latest/${JDK_VERSION}/ga/linux/x64/jdk/hotspot/normal/eclipse"
JDK_HOME="$WRAPPER_DIR/jdk-${JDK_VERSION}"
JDK_BIN="$JDK_HOME/bin/java"

if [ ! -x "$MAVEN_BIN" ]; then
  mkdir -p "$WRAPPER_DIR"
  ARCHIVE_PATH="$WRAPPER_DIR/$MAVEN_DIST"
  echo "Downloading Maven ${MAVEN_VERSION}..."
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$MAVEN_URL" -o "$ARCHIVE_PATH"
  elif command -v wget >/dev/null 2>&1; then
    wget -q -O "$ARCHIVE_PATH" "$MAVEN_URL"
  else
    echo "ERROR: curl or wget is required to download Maven." >&2
    exit 1
  fi

  echo "Extracting Maven..."
  tar -xzf "$ARCHIVE_PATH" -C "$WRAPPER_DIR"
fi

JAVA_MAJOR=0
if command -v java >/dev/null 2>&1; then
  JAVA_VERSION_RAW="$(java -version 2>&1 | awk -F '"' '/version/ {print $2}')"
  JAVA_FIRST="$(echo "$JAVA_VERSION_RAW" | cut -d. -f1)"
  JAVA_SECOND="$(echo "$JAVA_VERSION_RAW" | cut -d. -f2)"
  if [ "$JAVA_FIRST" = "1" ]; then
    JAVA_MAJOR="$JAVA_SECOND"
  else
    JAVA_MAJOR="$JAVA_FIRST"
  fi
fi

if [ "$JAVA_MAJOR" -lt 17 ]; then
  if [ ! -x "$JDK_BIN" ]; then
    mkdir -p "$WRAPPER_DIR"
    JDK_ARCHIVE_PATH="$WRAPPER_DIR/$JDK_DIST"
    echo "Java 17 not found. Downloading Temurin JDK 17..."
    if command -v curl >/dev/null 2>&1; then
      curl -fsSL "$JDK_URL" -o "$JDK_ARCHIVE_PATH"
    elif command -v wget >/dev/null 2>&1; then
      wget -q -O "$JDK_ARCHIVE_PATH" "$JDK_URL"
    else
      echo "ERROR: curl or wget is required to download JDK 17." >&2
      exit 1
    fi
    TMP_DIR="$WRAPPER_DIR/jdk-tmp"
    rm -rf "$TMP_DIR"
    mkdir -p "$TMP_DIR"
    tar -xzf "$JDK_ARCHIVE_PATH" -C "$TMP_DIR"
    FOUND_DIR="$(find "$TMP_DIR" -maxdepth 1 -type d | tail -n 1)"
    if [ -z "$FOUND_DIR" ]; then
      echo "ERROR: Failed to extract JDK archive." >&2
      exit 1
    fi
    rm -rf "$JDK_HOME"
    mv "$FOUND_DIR" "$JDK_HOME"
    rm -rf "$TMP_DIR"
  fi
  export JAVA_HOME="$JDK_HOME"
  export PATH="$JAVA_HOME/bin:$PATH"
fi

exec "$MAVEN_BIN" "$@"
